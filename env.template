# ─────────────────────────────────────────────────────────────────────────────
# Environment variable template — Linear-Clone Ticket System
#
# Copy to .env.local and fill in real values:   cp env.template .env.local
# .env.local is gitignored — NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required NOW (Wave 1 — apply the database migration) ─────────────────────

# Neon Postgres connection string.
#   Neon Console -> your Project -> Connection Details -> connection string.
#   MUST end with ?sslmode=require. Used by both Drizzle drivers and drizzle-kit.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require

# Better Auth signing secret (signs session cookies/tokens).
#   Generate with:  openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32

# Base URL Better Auth runs at, no trailing slash. Local dev = http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Public app URL exposed to the browser (used by the Better Auth client).
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ── Required for Wave 3 (GitHub OAuth sign-in) ───────────────────────────────
# Safe to fill in now. From github.com/settings/developers -> OAuth Apps -> New OAuth App
#   Homepage URL:               http://localhost:3000
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret
