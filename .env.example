# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit real secrets.

# Neon Postgres connection string (Neon Console -> Project -> Connection Details).
# Must include ?sslmode=require. Used by both Drizzle drivers and drizzle-kit.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require

# Better Auth signing secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32

# Base URL Better Auth runs at (no trailing slash).
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth App credentials (github.com/settings/developers -> OAuth Apps).
# Callback URL must be http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret

# Public app URL exposed to the browser (used by the Better Auth client).
NEXT_PUBLIC_APP_URL=http://localhost:3000
